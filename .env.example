#
# Copy to repo root as .env on the deploy server (e.g. /opt/cppa-weblate-plugin/.env).
# Used by docker/docker-compose.cd.yml and deploy.yml (docker compose --env-file .env).
#
# One-time host Postgres (as superuser):
#   CREATE USER weblate WITH PASSWORD 'same-as-POSTGRES_PASSWORD-below';
#   CREATE DATABASE weblate OWNER weblate;
# Ensure pg_hba.conf allows Docker bridge hosts to connect as weblate.

# --- Required (no defaults in compose) ---

POSTGRES_PASSWORD=replace-with-strong-password
WEBLATE_ADMIN_PASSWORD=replace-with-strong-admin-password

# --- Weblate ---

# Public hostname users see (nginx TLS terminates on this domain).
WEBLATE_SITE_DOMAIN=staging.insights.cppalliance.org

# Host port bound to 127.0.0.1 only; nginx proxies /weblate/ here.
WEBLATE_PORT=9103

# 0 for production, 1 only for debugging.
WEBLATE_DEBUG=0

# --- PostgreSQL (host, via host.docker.internal) ---

POSTGRES_USER=weblate
POSTGRES_DATABASE=weblate

# --- Redis (boost-data-collector stack; service name redis on external network) ---

# REDIS_HOST and REDIS_PORT are set in docker-compose.cd.yml.
# Use a separate Redis logical DB from other apps if you add REDIS_URL later.

# --- Celery ---

CELERY_SINGLE_PROCESS=1
